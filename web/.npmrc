# React 19 / react-leaflet peer-dependency reconciliation
# ------------------------------------------------------------
# react-leaflet 4.x declares peer ``react: ^17.0.0 || ^18.0.0``
# but this project is on React 19. ``npm ci`` on Vercel without
# ``--legacy-peer-deps`` fails the install. The switch is safe here
# because react-leaflet's runtime hook surface (``useMap`` etc) works
# on React 19 — the peer range is just a version-bound that hasn't
# been bumped upstream yet.
#
# Flag this file in .env.example if we bump to react-leaflet 5.x
# (which will support React 19 natively) so we can drop this override.
legacy-peer-deps=true

# Faster, quieter Vercel installs. Audits don't block here — we gate
# vulnerabilities at the repo level instead.
fund=false
audit=false
