# ---------------------------------------------------------------------------
# .env.example — 복사해서 `.env` 로 저장한 뒤 값을 채우세요.
#   cp .env.example .env
#
# 두 가지 방법 중 편한 쪽을 쓰면 됩니다.
#   (A) simulation/data/api_key.txt   ← 라벨 형식 파일 (api_key.example.txt 참고)
#   (B) 아래 환경변수                  ← (A)보다 우선순위가 높습니다(덮어씀)
# 둘을 섞어 써도 됩니다.
# ---------------------------------------------------------------------------

# === 국내 수집기 키 (simulation/database/config.py 가 읽는 이름) ===
SEOUL_KEY=              # 서울 열린데이터광장 일반인증키 (생활인구·상권)
SEOUL_SUBWAY=           # 서울 지하철 인증키
SEOUL_AIR=              # 서울 대기질 인증키
DATA_GO_KR=             # 공공데이터포털 서비스키 (Decoding)
KOSIS=                  # KOSIS 국가통계포털 인증키
NEIS=                   # NEIS 교육정보 개방 포털 인증키
KMA_HUB=                # 기상청 API 허브 인증키

# === 개별 수집기가 직접 읽는 키 ===
KMA_API_KEY=            # simulation/collectors/group_k_weather_gu.py (자치구 기상)
CENSUS_API_KEY=         # simulation/collectors/group_j_population_density.py (US Census, 해외 비교)
NEDIS_API_KEY=          # simulation/collectors/group_n_hospital.py (응급의료, 선택)
ESTAT_APP_ID=           # 일본 e-Stat (해외 비교, 선택)
ESTAT_API_KEY=          # 일본 e-Stat (해외 비교, 선택)
TABPFN_TOKEN=           # TabPFN 표형 파운데이션 모델 (선택)

# === ARIA 자문 계층 LLM 백엔드 (전부 선택 — 없으면 ARIA 레이어만 비활성) ===
ANTHROPIC_API_KEY=      # 또는 CLAUDE_API_KEY
OPENAI_API_KEY=
GEMINI_API_KEY=         # 또는 GOOGLE_API_KEY
OPENAI_COMPAT_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434   # 로컬 Ollama 사용 시

# === 웹 대시보드 지도 레이어 (web/, 전부 선택) ===
NEXT_PUBLIC_VWORLD_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_KAKAO_MAP_KEY=
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
NASA_EARTHDATA_TOKEN=

# === 실행 옵션 (키 아님, 기본값 권장) ===
# ENGINEERING_PRINCIPLES.md 의 "학습 운영 표준" 참고
OPTUNA_ISOLATE=1
MPH_BEST_BY=oof_cv
MPH_EVAL_FEATURES=basic
