# ============================================================================
# .gitignore — 배포(공개) 저장소 전용
#
# 원칙
#   추적한다 : 소스코드 · 논문 산출물(paper/) · 분석 결과물(simulation/results/) · PPT
#   무시한다 : 비밀정보 · 대용량 원본데이터 · 모델 가중치 · 빌드/캐시 산출물
#
# ⚠ 작업용 저장소의 .gitignore 를 그대로 쓰면 paper/ 와 simulation/results/ 가
#   통째로 무시되어 "결과물 공개"라는 배포 목적이 깨집니다. 그래서 이 파일은 별도입니다.
# ============================================================================

# ---------- 비밀정보 (절대 커밋 금지) ----------
.env
.env.*
!.env.example
**/api_key.txt
simulation/data/*.key
!simulation/data/api_key.example.txt
*.pem
*credentials*.json

# ---------- 데이터베이스 (SETUP.md 절차로 재생성) ----------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
simulation/data/db/
simulation/data/collected/
simulation/data/staging/

# ---------- 모델 가중치 (GitHub 100MB 제한 · 학습으로 재생성) ----------
*.pt
*.pth
*.ckpt
*.onnx
*.safetensors
models/

# ---------- 파이썬 / 가상환경 ----------
.venv/
venv/
.python-version
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# ---------- Node / 웹 ----------
node_modules/
web/.next/
web/out/
web/build/
.turbo/

# ---------- Rust / 네이티브 빌드 ----------
simulation/rust/target/
simulation/rust/python/seir_core/
*.dylib
*.so
*.rlib

# ---------- 로그 / 실험 추적 ----------
lightning_logs/
sbi-logs/
logs/
simulation/logs/
*.log
mlruns/
mlartifacts/
optuna*.db

# ---------- 캐시 (패키지 코드는 유지, 캐시 데이터만 제외) ----------
simulation/cache/*
!simulation/cache/__init__.py
*.parquet

# ---------- OS / 편집기 ----------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---------- 작업 부산물 (배포 대상 아님) ----------
_archive*/
_trash/
archive/
paper/backup/
paper/_pre_*
paper/*_check*.pdf
paper/unpacked_*/
simulation/results/_archive_fullrun_*/
simulation/results/_backup_*/
simulation/results/_csv_sweep_polluted_*/
simulation/results/_bak_*/

# ---------- 학위논문 본문 (학위수여/도서관 제출 전 비공개) ----------
# 수여 후 공개하려면 아래 4줄을 지우고 다시 add 하세요.
paper/고려대_보건석사학위논문_이승진_2026.docx
paper/고려대_보건석사학위논문_이승진_2026.pdf
paper/supplementary_models.docx
paper/3.고려대학교_학위논문_영문양식_MS_Word.docx

# ---------- 제3자 원본 문서 (재배포권 불명확 — 사용자가 직접 배치) ----------
# extract_pdf.py 는 "caller must copy it into simulation/data/pdf/ explicitly" 설계입니다.
simulation/data/pdf/*.pdf
!simulation/data/pdf/.gitkeep

# Distribution hygiene — scratch logs and editor backups must not ship
scripts/_exp_*.log
*.bak
*.orig
**/_backup_*/

# Script intermediate artifacts (MPH_SCRATCH override)
_scratch/
*.bak[0-9]
*.bak[0-9][0-9]
*.bak_*

# Generated by web/scripts/01_preflight_local.ps1 — machine-specific paths, not source
web/scripts/preflight_local_report.json
simulation/results/comprehensive_eval.pre_regen/
simulation/results/checkpoints.pre_sync/

# test side-effect (a feature-selection test writes here)
simulation/results/per_model_research_features/
simulation/results/optuna_dnn_best.json
simulation/results/optuna_tcn_best.json
